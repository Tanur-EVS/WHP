# REPLACE the whole function with this
def write_part_details_table(ws, row, col, part_number, description):
    section_font = Font(name="Arial", bold=True, color="FFFFFF", size=10)
    section_fill = PatternFill("solid", fgColor="4472C4")
    label_font   = Font(name="Arial", bold=True, size=10)
    value_font   = Font(name="Arial", size=10)
    left_align   = Alignment(horizontal="left", vertical="center")

    # Section header spanning 2 columns
    ws.merge_cells(start_row=row, start_column=col, end_row=row, end_column=col+1)
    cell           = ws.cell(row=row, column=col)
    cell.value     = "Part Details"
    cell.font      = section_font
    cell.fill      = section_fill
    cell.alignment = left_align
    ws.row_dimensions[row].height = 18

    # Part Number row
    ws.cell(row=row+1, column=col,   value="Part Number").font = label_font
    ws.cell(row=row+1, column=col+1, value=part_number).font   = value_font

    # Description row
    ws.cell(row=row+2, column=col,   value="Description").font = label_font
    ws.cell(row=row+2, column=col+1, value=description).font   = value_font

    # Set column widths
    from openpyxl.utils import get_column_letter
    ws.column_dimensions[get_column_letter(col)].width   = 20
    ws.column_dimensions[get_column_letter(col+1)].width = 35
