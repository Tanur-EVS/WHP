import google.generativeai as genai
from pdf2image import convert_from_path
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment
import base64
import json

# ── CONFIG ────────────────────────────────────────────────────────
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"
PDF_FILE_PATH  = r"C:\Users\Tanur.Yadav\Documents\WHR\your_cad_file.pdf"
OUTPUT_EXCEL   = r"C:\Users\Tanur.Yadav\Documents\WHR\parts_output.xlsx"
# ─────────────────────────────────────────────────────────────────

# ── STEP 1: Convert PDF to PNG ────────────────────────────────────
print("Step 1/3 — Converting PDF to image...")
pages = convert_from_path(PDF_FILE_PATH, dpi=300)
image_path = "temp_page.png"
pages[0].save(image_path, "PNG")

# ── STEP 2: Send to Gemini ────────────────────────────────────────
print("Step 2/3 — Extracting parts via Gemini...")
genai.configure(api_key=GEMINI_API_KEY)
model = genai.GenerativeModel("gemini-1.5-pro")

with open(image_path, "rb") as f:
    image_data = base64.b64encode(f.read()).decode("utf-8")

prompt = """
This is a CAD 2D engineering drawing BOM table.
Extract all rows from the parts list table at the bottom of the drawing.
Each main part has sub-components in the same row.

Return as JSON only, no extra text, no markdown, no backticks:
[
    {
        "part_number": "W11791017",
        "rev": "A",
        "description": "POCKET ADHESIVE HANDLE ASSY,BLK",
        "sub_components": [
            {"part_number": "W11791013", "description": "PROSTAR POCKET PANEL"},
            {"part_number": "W11242122", "description": "POCKET HANDLE"}
        ]
    }
]
"""

response = model.generate_content([
    {
        "inline_data": {
            "mime_type": "image/png",
            "data": image_data
        }
    },
    prompt
])

parts = json.loads(response.text)
print(f"  → Found {len(parts)} parts: {[p['part_number'] for p in parts]}")

# ── STEP 3: Write to Excel ────────────────────────────────────────
print("Step 3/3 — Writing to Excel...")

def write_part_details_table(ws, start_row, part_number, description):
    section_font = Font(name="Arial", bold=True, color="FFFFFF", size=10)
    section_fill = PatternFill("solid", fgColor="4472C4")
    label_font   = Font(name="Arial", bold=True, size=10)
    value_font   = Font(name="Arial", size=10)
    left_align   = Alignment(horizontal="left", vertical="center")

    ws.merge_cells(f"A{start_row}:B{start_row}")
    cell           = ws[f"A{start_row}"]
    cell.value     = "Part Details"
    cell.font      = section_font
    cell.fill      = section_fill
    cell.alignment = left_align
    ws.row_dimensions[start_row].height = 18

    ws.cell(row=start_row+1, column=1, value="Part Number").font = label_font
    ws.cell(row=start_row+1, column=2, value=part_number).font   = value_font
    ws.cell(row=start_row+2, column=1, value="Description").font = label_font
    ws.cell(row=start_row+2, column=2, value=description).font   = value_font

    return start_row + 4

wb = Workbook()

# Summary sheet
ws_summary = wb.active
ws_summary.title = "Summary"
header_font  = Font(name="Arial", bold=True, color="FFFFFF", size=11)
header_fill  = PatternFill("solid", fgColor="2E4057")
center_align = Alignment(horizontal="center", vertical="center")
value_font   = Font(name="Arial", size=10)

for col, label in enumerate(["Part Number", "Rev", "Description"], 1):
    cell            = ws_summary.cell(row=1, column=col, value=label)
    cell.font       = header_font
    cell.fill       = header_fill
    cell.alignment  = center_align

for i, part in enumerate(parts, 2):
    ws_summary.cell(row=i, column=1, value=part["part_number"]).font = value_font
    ws_summary.cell(row=i, column=2, value=part["rev"]).font         = value_font
    ws_summary.cell(row=i, column=3, value=part["description"]).font = value_font

ws_summary.column_dimensions["A"].width = 20
ws_summary.column_dimensions["B"].width = 8
ws_summary.column_dimensions["C"].width = 45

# Individual sheets
for part in parts:
    ws = wb.create_sheet(title=part["part_number"])
    ws.column_dimensions["A"].width = 25
    ws.column_dimensions["B"].width = 45

    current_row = 1

    # Main part table
    current_row = write_part_details_table(
        ws, current_row,
        part["part_number"],
        part["description"]
    )

    # Sub-component tables
    for sub in part["sub_components"]:
        current_row = write_part_details_table(
            ws, current_row,
            sub["part_number"],
            sub["description"]
        )

wb.save(OUTPUT_EXCEL)
print(f"\nDone! Open {OUTPUT_EXCEL} to review.")
