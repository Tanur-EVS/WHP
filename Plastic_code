print("Writing to Excel...")

def extract_info_from_bom(BOM_FILE_PATH: str) -> dict:
    df = pd.read_excel(BOM_FILE_PATH, header=4)
    df.dropna(axis=0, how="all", inplace =True)
    data = df.iloc[4:].rest_index(drop=True)
    data = data[data["Part Number"].notna()]
    data = data[data["Part Number"].astype(str).str.startswith("W")]

    bom_lookup = {}
    for _, row in data.iterrows():
        part_number = str(row["Part Number"]).strip()
        vpe = str(row["VPE"]).strip()
        econ_date = str(row["Economic Date"]).strip()
        bom_lookup[part_number] ={
            "annual_volume": row["Production Volume"],
            "manufacturing_region": f"{vpe}-{econ_date}".replace("nan","").strip("-"),
            "cost_currency": "USD",
        }
    return bom_lookup

def write_part_details_table(ws, row, col, part_number, description, bom_data):
    section_font = Font(name="Arial", bold=True, color="FFFFFF", size=10)
    section_fill = PatternFill("solid", fgColor="90B8E0")
    label_font   = Font(name="Arial", bold=True, size=10)
    value_font   = Font(name="Arial", size=10)
    left_align   = Alignment(horizontal="left", vertical="center")
    header_font = Font(name="Arial", bold=True, size = 9)
    header_fill = PatternFill("solid", fgColor="90B8E0")
    center_align = Alignment(horizontal="centre", vertical="center")


    # Section header spanning 2 columns
    cell           = ws.cell(row=row, column=col)
    cell.value     = "Part Details"
    cell.font      = section_font
    cell.fill      = section_fill
    cell.alignment = left_align
    ws.row_dimensions[row].height = 18

    # Part Number row
    ws.cell(row=row+1, column=col,   value="Part Number").font = label_font
    ws.cell(row=row+1, column=col+1, value=part_number).font   = value_font

    # Description row
    ws.cell(row=row+2, column=col,   value="Description").font = label_font
    ws.cell(row=row+2, column=col+1, value=description).font   = value_font

    # New rows from BOM
    for offset, label in enumerate(["Cost Model", "Quote", "Gap"], start=1):
        cell = ws.cell(row=row+3, column = col+offset, value=label)
        cell.font = header_font
        cell.fill = header_fill
        cell.alignment = center_align
    
    ws.cell(row=row+4, column = col, value = "Revision or Package No.").font = label_font

    ws.cell(row=row+5, column = col, value = "Annual Volume").font = label_font
    ws.cell(row=row+5, column = col+1, value =bom_data.get("annual_volume","")).font = value_font

    ws.cell(row=row+6, column = col, value = "Manufacturing Region").font = label_font
    ws.cell(row=row+6, column = col+1, value = bom_data.get("manufacturing_region")).font = value_font

    ws.cell(row=row+7 , column = col , value = "Cost Currency").Font = value_font
    ws.cell(row=row+7, column = col+1, value = "USD").font = label_font



    # Set column widths
    from openpyxl.utils import get_column_letter
    ws.column_dimensions[get_column_letter(col)].width   = 20
    ws.column_dimensions[get_column_letter(col+1)].width = 25
    ws.column_dimensions[get_column_letter(col+2)].width = 12
    ws.column_dimensions[get_column_letter(col+3)].width = 8


wb = Workbook()
wb.remove(wb.active)
bom_lookup = extract_info_from_bom(BOM_FILE_PATH)
# Individual sheets
for part in parts:   
    ws = wb.create_sheet(title=part["part_number"])
    ws.column_dimensions["A"].width=25

    bom_data = bom_lookup.get(part["part_number"],{})

    # Tables side by side — each table starts at column offset
    # Table 1 = sub[0] starts at col A
    # Table 2 = sub[1] starts at col D
    # Table 3 = main part starts at col G

    tables = part["sub_components"] + [{"part_number": part["part_number"], "description": part["description"]}]

    for t_idx, table in enumerate(tables):
        start_col = 1 + (t_idx * 5)  # A=1, D=4, G=7 (gap of 3 columns per table)
        write_part_details_table(ws, row=1, col=start_col,
                                 part_number=table["part_number"],
                                 description=table["description"],
                                 bom_data = bom_data)

wb.save(OUTPUT_EXCEL)
